# A2A Bridge API Environment Variables

# Redis Connection (required)
REDIS_URL=redis://default:password@host:6379

# Port (default: 3000)
PORT=3000

# Host (default: 0.0.0.0)
HOST=0.0.0.0

# Environment (development|production)
NODE_ENV=production

# API Version (default: 2.1.0)
API_VERSION=2.1.0

# Pre-configured Webhooks (optional - can register via API instead)
BADGER1_WEBHOOK=http://132.145.145.26:18789/hooks/wake
RATCHET_WEBHOOK=http://198.199.86.203:18789/hooks/wake

# Default Webhook Token
DEFAULT_WEBHOOK_TOKEN=twin-webhook-secret-2026

# Message Limits (optional)
MAX_MESSAGES_PER_AGENT=1000
MAX_MESSAGE_SIZE=65536

# Task Limits (optional)
MAX_TASKS_PER_AGENT=100

# Logging (optional)
LOG_LEVEL=info
